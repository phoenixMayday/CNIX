// print(fd, content) calls the write syscall and returns bytes written.
// fd 1 = stdout, fd 2 = stderr.

// --- named char[] variable ---
char[] greeting = "Hello, World!\n";
_ = print(1, greeting);

// --- inline array literal ---
_ = print(1, {'O', 'K', '\n'});

_ = print(1, "{'e'}{'v'}{'a'}{'\n'}");

char[] str = "eva";
_ = print(1, "Hello {str}!\n");

exit(0);
